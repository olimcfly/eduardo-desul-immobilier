# .htaccess (racine)
DirectoryIndex public/index.php index.php

RewriteEngine On

# Autoriser les fichiers/dossiers réels à la racine
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Bloquer l'accès direct aux dossiers sensibles
RewriteRule ^(config|logs|vendor|storage)(/.*)?$ - [F,L]

# Router front: si le vhost pointe sur la racine du dépôt,
# on délègue toutes les URLs applicatives à public/index.php.
RewriteRule ^ public/index.php [QSA,L]

# Cache
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript
</IfModule>

# Erreurs
ErrorDocument 404 /public/index.php
